rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ヘルパー関数
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasAccessToStore(storeId) {
      let userStoreDoc = get(/databases/$(database)/documents/userStoreAccess/$(request.auth.uid));
      return (userStoreDoc != null && 
              userStoreDoc.data != null && 
              storeId in userStoreDoc.data.storesAccess &&
              userStoreDoc.data.storesAccess[storeId].isActive == true) ||
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId == storeId);
    }

    function isMasterOfStore(storeId) {
      return hasAccessToStore(storeId) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "master");
    }

    // ログイン用（全読み取り可能）
    match /users/{userId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /userStoreAccess/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // 店舗情報
    match /stores/{storeId} {
      allow read: if hasAccessToStore(storeId);
      allow write: if isMasterOfStore(storeId);
    }

    // シフトコレクション - 店舗分離 + 所有者/マスター制御
    match /shifts/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // 募集シフトコレクション - 店舗分離
    match /recruitmentShifts/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // タスクコレクション - 店舗分離
    match /NormalTasks/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // タスクメモコレクション - タスクの店舗に基づく
    match /TaskMemos/{docId} {
      allow read, write: if isAuthenticated() && 
        hasAccessToStore(get(/databases/$(database)/documents/NormalTasks/$(resource.data.taskId)).data.storeId);
    }

    // 拡張タスクコレクション - 店舗分離
    match /extendedTasks/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // ファイルコレクション - 店舗分離
    match /files/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // フォルダコレクション - 店舗分離
    match /folders/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // 設定コレクション - 全認証ユーザー読み取り可能、マスターのみ書き込み可能
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "master";
    }

    // 未定義のパスは拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}