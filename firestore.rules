rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ヘルパー関数
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasAccessToStore(storeId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      let userStoreDoc = get(/databases/$(database)/documents/userStoreAccess/$(request.auth.uid));
      
      return (userDoc != null && userDoc.data.storeId == storeId) ||
             (userStoreDoc != null && 
              userStoreDoc.data != null && 
              storeId in userStoreDoc.data.storesAccess &&
              userStoreDoc.data.storesAccess[storeId].isActive == true);
    }

    function isMasterOfStore(storeId) {
      return hasAccessToStore(storeId) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "master");
    }

    // 新規教室（store）作成の管理
    function canCreateNewStore() {
      // 認証されたユーザーで、まだどの店舗にも属していない
      return isAuthenticated() && 
             (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('storeId', null) == null);
    }

    // ユーザー管理 - 店舗分離 + 権限制御
    match /users/{userId} {
      // 読み取り: 認証されたユーザー（ログイン画面で必要）または同一店舗のユーザー
      allow read: if true;  // ログイン時に必要なため全読み取り可能
      
      // 作成: 認証されたマスターユーザーが作成可能 OR 新規教室作成
      allow create: if isAuthenticated() && 
        request.resource.data.storeId != null &&
        (
          // 既存マスターが作成
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "master" &&
           hasAccessToStore(request.resource.data.storeId))
          ||
          // 新規教室作成（マスターユーザー）
          (request.auth.uid == userId && 
           request.resource.data.role == "master" &&
           canCreateNewStore())
        );
      
      // 更新: 本人またはマスター（同一店舗）
      allow update: if isAuthenticated() && 
        (request.auth.uid == userId || 
         (hasAccessToStore(resource.data.storeId) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "master"));
      
      // 削除: マスターのみ（同一店舗）
      allow delete: if isAuthenticated() && 
        hasAccessToStore(resource.data.storeId) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "master";
    }

    match /userStoreAccess/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // 店舗情報 - 新規作成を許可
    match /stores/{storeId} {
      allow read: if hasAccessToStore(storeId);
      allow create: if isAuthenticated() && 
        (canCreateNewStore() || isMasterOfStore(storeId));
      allow update, delete: if isMasterOfStore(storeId);
    }

    // シフトコレクション - 店舗分離 + 所有者/マスター制御
    match /shifts/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // 募集シフトコレクション - 店舗分離
    match /recruitmentShifts/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // タスクコレクション - 店舗分離
    match /NormalTasks/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // タスクメモコレクション - タスクの店舗に基づく
    match /TaskMemos/{docId} {
      allow read, write: if isAuthenticated() && 
        hasAccessToStore(get(/databases/$(database)/documents/NormalTasks/$(resource.data.taskId)).data.storeId);
    }

    // 拡張タスクコレクション - 店舗分離
    match /extendedTasks/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // ファイルコレクション - 店舗分離（緩和版）
    match /files/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      // ファイル作成時のアクセス確認を緩和
      allow create: if isAuthenticated() && 
        (hasAccessToStore(request.resource.data.storeId) ||
         // フォールバック: ユーザーの storeId と一致
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId == request.resource.data.storeId));
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // フォルダコレクション - 店舗分離（緩和版）
    match /folders/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      // フォルダ作成時のアクセス確認を緩和
      allow create: if isAuthenticated() && 
        (hasAccessToStore(request.resource.data.storeId) ||
         // フォールバック: ユーザーの storeId と一致
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId == request.resource.data.storeId));
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // 設定コレクション - 全認証ユーザー読み取り可能、マスターのみ書き込み可能
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "master";
    }

    // シフト変更ログコレクション - 店舗分離、マスターのみアクセス可能
    match /shiftChangeLogs/{docId} {
      allow read: if isAuthenticated() && 
        isMasterOfStore(resource.data.storeId);
      allow create: if isAuthenticated() && 
        hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if false; // 追記専用
    }

    // 未定義のパスは拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}