rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ヘルパー関数
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasAccessToStore(storeId) {
      // 🔒 セキュア化：カスタムトークンベース（get()完全排除）
      // ✅ SECURITY: 追加の検証層
      return isAuthenticated() &&
             storeId != null &&
             storeId != "" &&
             (request.auth.token.storeId == storeId ||
             (request.auth.token.storesAccess != null && 
              storeId in request.auth.token.storesAccess &&
              request.auth.token.storesAccess[storeId].isActive == true)) &&
             // 🔒 トークン有効期限の検証
             request.auth.token.iat != null &&
             request.time.toMillis() - request.auth.token.iat * 1000 < 86400000; // 24時間
    }

    function isMasterOfStore(storeId) {
      return hasAccessToStore(storeId) &&
        (request.auth.token.role == "master");
    }

    // 新規教室（store）作成の管理
    function canCreateNewStore() {
      // 認証されたユーザーで、まだどの店舗にも属していない
      return isAuthenticated() && 
             (request.auth.token.storeId == null || request.auth.token.storeId == "");
    }

    // ユーザー管理 - 店舗分離 + 権限制御
    match /users/{userId} {
      // 読み取り: 本人のデータ OR 同じ店舗のマスター
      // 🔒 SECURITY FIX: secureLogin経由のカスタムトークンのみ許可
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        // マスターは同じ店舗の全ユーザーを閲覧可能（強化された検証）
        (request.auth.token.role == "master" && 
         resource.data.storeId == request.auth.token.storeId &&
         resource.data.deleted != true && // 🔒 削除済みユーザーの隠蔽
         hasAccessToStore(resource.data.storeId))
      );
      
      // 作成: 認証されたマスターユーザーが作成可能 OR 新規教室作成
      allow create: if isAuthenticated() && 
        request.resource.data.storeId != null &&
        request.resource.data.storeId != "" &&
        // 🔒 SECURITY: 必須フィールドの検証
        request.resource.data.nickname != null &&
        request.resource.data.email != null &&
        request.resource.data.role in ["master", "user"] &&
        // 🔒 SECURITY: 機密フィールドの制限
        !("currentPassword" in request.resource.data) && // 平文パスワード禁止
        (
          // 既存マスターが作成
          (request.auth.token.role == "master" &&
           hasAccessToStore(request.resource.data.storeId))
          ||
          // 新規教室作成（マスターユーザー）
          (request.auth.uid == userId && 
           request.resource.data.role == "master" &&
           canCreateNewStore())
        );
      
      // 更新: 本人またはマスター（同一店舗）
      allow update: if isAuthenticated() && 
        // 🔒 SECURITY: 機密フィールドの保護
        !("currentPassword" in request.resource.data) && // 平文パスワード禁止
        resource.data.deleted != true && // 削除済みユーザーの更新禁止
        (request.auth.uid == userId || 
         (hasAccessToStore(resource.data.storeId) &&
          request.auth.token.role == "master" &&
          // 🔒 マスターによる権限昇格防止
          (request.auth.uid == userId || request.resource.data.role == resource.data.role)));
      
      // 削除: マスターのみ（同一店舗）
      allow delete: if isAuthenticated() && 
        hasAccessToStore(resource.data.storeId) &&
        request.auth.token.role == "master";
    }

    match /userStoreAccess/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // 店舗情報 - 新規作成を許可
    match /stores/{storeId} {
      allow read: if hasAccessToStore(storeId);
      allow create: if isAuthenticated() && 
        (canCreateNewStore() || isMasterOfStore(storeId));
      allow update, delete: if isMasterOfStore(storeId);
    }

    // シフトコレクション - 店舗分離 + 所有者/マスター制御
    match /shifts/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // 募集シフトコレクション - 店舗分離
    match /recruitmentShifts/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // タスクコレクション - 店舗分離
    match /NormalTasks/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // タスクメモコレクション - 直接的な店舗分離
    match /TaskMemos/{docId} {
      allow read, write: if isAuthenticated() && 
        hasAccessToStore(resource.data.storeId);
    }

    // 拡張タスクコレクション - 店舗分離
    match /extendedTasks/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // ファイルコレクション - 店舗分離（緩和版）
    match /files/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      // ファイル作成時のアクセス確認を緩和
      allow create: if isAuthenticated() && 
        (hasAccessToStore(request.resource.data.storeId) ||
         // フォールバック: ユーザーの storeId と一致
         request.auth.token.storeId == request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // フォルダコレクション - 店舗分離（緩和版）
    match /folders/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      // フォルダ作成時のアクセス確認を緩和
      allow create: if isAuthenticated() && 
        (hasAccessToStore(request.resource.data.storeId) ||
         // フォールバック: ユーザーの storeId と一致
         request.auth.token.storeId == request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // 設定コレクション - 全認証ユーザー読み取り可能、マスターのみ書き込み可能
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        request.auth.token.role == "master";
    }

    // シフト変更ログコレクション - 店舗分離、マスターのみアクセス可能
    match /shiftChangeLogs/{docId} {
      allow read: if isAuthenticated() && 
        isMasterOfStore(resource.data.storeId);
      allow create: if isAuthenticated() && 
        hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if false; // 追記専用
    }

    // 未定義のパスは拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}