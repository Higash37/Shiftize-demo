rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ヘルパー関数
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasAccessToStore(storeId) {
      // 🔒 セキュア化：カスタムトークンベース（get()完全排除）
      // ✅ SECURITY: 追加の検証層
      // 新規ユーザー（カスタムクレームなし）の場合はfalseを返す
      return isAuthenticated() &&
             storeId != null &&
             storeId != "" &&
             // カスタムクレームが存在する場合のみチェック
             request.auth.token.storeId != null &&
             (request.auth.token.storeId == storeId ||
             (request.auth.token.storesAccess != null && 
              storeId in request.auth.token.storesAccess &&
              request.auth.token.storesAccess[storeId].isActive == true)) &&
             // 🔒 トークン有効期限の検証
             request.auth.token.iat != null &&
             request.time.toMillis() - request.auth.token.iat * 1000 < 86400000; // 24時間
    }

    function isMasterOfStore(storeId) {
      return hasAccessToStore(storeId) &&
        (request.auth.token.role == "master");
    }

    // 新規教室（store）作成の管理
    function canCreateNewStore() {
      // 認証されたユーザーで、まだどの店舗にも属していない
      // 🔒 SECURITY: 新規作成ユーザーはカスタムクレームを持たないため、認証のみチェック
      // 新規ユーザーはカスタムクレーム（storeId, role等）を持たないため、
      // トークンの有無に関わらず認証されていれば許可
      // 注意: Firestoreルールでは存在しないプロパティはnullを返すため、
      // storeIdがnullまたは空文字列の場合を新規ユーザーとみなす
      // ただし、存在しないプロパティにアクセスするとエラーになる可能性があるため、
      // より安全な方法として、認証されているユーザーがadminUidとして自分自身を設定する場合のみ許可
      // これにより、新規ユーザーでも確実にストアを作成できる
      // 新規ユーザーはカスタムクレームを持たないため、storeIdが存在しないかnullの場合を許可
      return isAuthenticated() &&
             // カスタムクレームがない場合（新規ユーザー）を許可
             // request.auth.token 自体がnullになるケースも許可
             ((request.auth.token == null) ||
              request.auth.token.storeId == null || 
              request.auth.token.storeId == "");
    }

    // ユーザー管理 - 店舗分離 + 権限制御
    match /users/{userId} {
      // 読み取り: 本人のデータ OR 同じ店舗のマスター
      // 🔒 SECURITY FIX: secureLogin経由のカスタムトークンのみ許可
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        // マスターは同じ店舗の全ユーザーを閲覧可能（強化された検証）
        (request.auth.token.role == "master" &&
         resource.data.storeId == request.auth.token.storeId &&
         resource.data.deleted != true && // 🔒 削除済みユーザーの隠蔽
         hasAccessToStore(resource.data.storeId))
      );

      // 🔒 NEW: コレクションクエリ許可（マスターのみ、同一店舗内）
      allow list: if isAuthenticated() &&
        request.auth.token.role == "master" &&
        // storeIdでフィルタされたクエリのみ許可
        resource.data.storeId == request.auth.token.storeId &&
        hasAccessToStore(request.auth.token.storeId);

      // 作成: 認証されたマスターユーザーが作成可能 OR 新規グループ作成
      allow create: if isAuthenticated() &&
        request.resource.data.uid == userId &&
        request.resource.data.storeId != null &&
        request.resource.data.storeId != "" &&
        request.resource.data.nickname != null &&
        request.resource.data.email != null &&
        request.resource.data.role in ["master", "user"] &&
        (
          // 既存マスターが作成
          (request.auth.token.role == "master" &&
           hasAccessToStore(request.resource.data.storeId)) ||
          // 新規グループ作成（マスターユーザー）
          (request.auth.uid == userId &&
           request.resource.data.role == "master" &&
           canCreateNewStore())
        );

      // 更新: 本人またはマスター（同一店舗）
      allow update: if isAuthenticated() && 
        // ⚠️ Legacy: currentPassword を保存 (移行中)
        resource.data.deleted != true && // 削除済みユーザーの更新禁止
        (request.auth.uid == userId || 
         (hasAccessToStore(resource.data.storeId) &&
          request.auth.token.role == "master" &&
          // 🔒 マスターによる権限昇格防止
          (request.auth.uid == userId || request.resource.data.role == resource.data.role)));
      
      // 削除: マスターのみ（同一店舗）
      allow delete: if isAuthenticated() && 
        hasAccessToStore(resource.data.storeId) &&
        request.auth.token.role == "master";
    }

    match /userStoreAccess/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // 店舗情報 - 新規作成を許可
    match /stores/{storeId} {
      // get: 店舗IDの存在確認用（未認証でも許可 - 新規グループ作成時の重複チェック用）
      allow get: if true;

      // list: 認証済みユーザーのみ
      allow list: if hasAccessToStore(storeId);

      // 作成: 新規グループ作成時のみ許可（管理者が自分自身をadminUidとして設定）
      allow create: if isAuthenticated() &&
        request.resource.data.adminUid == request.auth.uid &&
        request.resource.data.storeId == storeId &&
        request.resource.data.storeName != null &&
        request.resource.data.isActive == true &&
        canCreateNewStore();

      allow update, delete: if isMasterOfStore(storeId);
    }

    // シフトコレクション - 店舗分離 + 所有者/マスター制御
    match /shifts/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // 募集シフトコレクション - 店舗分離
    match /recruitmentShifts/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // タスクコレクション - 店舗分離
    match /NormalTasks/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // タスクメモコレクション - 直接的な店舗分離
    match /TaskMemos/{docId} {
      allow read, write: if isAuthenticated() && 
        hasAccessToStore(resource.data.storeId);
    }

    // 拡張タスクコレクション - 店舗分離
    match /extendedTasks/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      allow create: if isAuthenticated() && hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // ファイルコレクション - 店舗分離（緩和版）
    match /files/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      // ファイル作成時のアクセス確認を緩和
      allow create: if isAuthenticated() && 
        (hasAccessToStore(request.resource.data.storeId) ||
         // フォールバック: ユーザーの storeId と一致
         request.auth.token.storeId == request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // フォルダコレクション - 店舗分離（緩和版）
    match /folders/{docId} {
      allow read: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
      // フォルダ作成時のアクセス確認を緩和
      allow create: if isAuthenticated() && 
        (hasAccessToStore(request.resource.data.storeId) ||
         // フォールバック: ユーザーの storeId と一致
         request.auth.token.storeId == request.resource.data.storeId);
      allow update, delete: if isAuthenticated() && hasAccessToStore(resource.data.storeId);
    }

    // 設定コレクション - 全認証ユーザー読み取り可能、マスターのみ書き込み可能
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        request.auth.token.role == "master";
    }

    // シフト変更ログコレクション - 店舗分離、マスターのみアクセス可能
    match /shiftChangeLogs/{docId} {
      // 読み取り: マスターのみ、自分の店舗のデータのみ
      // クエリでwhere("storeId", "==", storeId)を使っているので、
      // ドキュメントのstoreIdが認証トークンのstoreIdと一致するか確認
      allow read: if isAuthenticated() && 
        request.auth.token.role == "master" &&
        (
          // メインのstoreIdと一致
          resource.data.storeId == request.auth.token.storeId ||
          // または、連携店舗アクセス権限がある場合
          (request.auth.token.storesAccess != null && 
           resource.data.storeId in request.auth.token.storesAccess &&
           request.auth.token.storesAccess[resource.data.storeId].isActive == true)
        );
      allow create: if isAuthenticated() && 
        hasAccessToStore(request.resource.data.storeId);
      allow update, delete: if false; // 追記専用
    }

    // 未定義のパスは拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
