};

// 高度なシフト作成の最終処理
const processAdvancedShiftCreation = async (client: Client, replyToken: string, postbackData: any, lineUserId: string) => {
  try {
    const hashedLineUserId = crypto.createHash('sha256').update(lineUserId).digest('hex');
    const sessionRef = admin.firestore().collection('line_shift_sessions').doc(hashedLineUserId);
    const sessionDoc = await sessionRef.get();

    if (!sessionDoc.exists) {
      await client.replyMessage(replyToken, {
        type: 'text',
        text: 'セッションが見つかりません。「シフト追加」からやり直してください。'
      });
      return;
    }

    const session = sessionDoc.data() as ShiftCreationSession;
    const firebaseUid = await decryptData(session.userId);

    // ユーザー情報取得
    const userDoc = await admin.firestore().collection('users').doc(firebaseUid).get();
    if (!userDoc.exists) {
      await client.replyMessage(replyToken, {
        type: 'text',
        text: 'ユーザー情報が見つかりません。'
      });
      return;
    }

    const userData = userDoc.data();
    if (!userData) {
      await client.replyMessage(replyToken, {
        type: 'text',
        text: 'ユーザーデータの取得に失敗しました。'
      });
      return;
    }

    // 各日付に対してシフトを作成
    const createdShifts = [];
    for (const date of session.selectedDates) {
      const shiftId = admin.firestore().collection('shifts').doc().id;

      const shiftData = {
        id: shiftId,
        date: date,
        startTime: session.selectedStartTime,
        endTime: session.selectedEndTime,
        userId: firebaseUid,
        storeId: userData.storeId,
        status: 'pending',
        nickname: userData.nickname || '名前なし',
        classes: session.classes.map((classItem, index) => ({
          id: `class_${index}`,
          startTime: classItem.startTime,
          endTime: classItem.endTime
        })),
        createdAt: admin.firestore.FieldValue.serverTimestamp(),
        updatedAt: admin.firestore.FieldValue.serverTimestamp(),
        createdBy: firebaseUid
      };

      await admin.firestore().collection('shifts').doc(shiftId).set(shiftData);
      createdShifts.push({
        date: new Date(date).toLocaleDateString('ja-JP'),
        startTime: session.selectedStartTime,
        endTime: session.selectedEndTime
      });
    }

    // セッションをクリア
    await sessionRef.delete();

    // 成功メッセージ
    const shiftsText = createdShifts.map(shift =>
      `• ${shift.date} ${shift.startTime}-${shift.endTime}`
    ).join('\n');

    const classesText = session.classes.length > 0
      ? '\n\n📚 授業:\n' + session.classes.map((classItem, index) =>
          `• 授業${index + 1}: ${classItem.startTime}-${classItem.endTime}`
        ).join('\n')
      : '';

    await client.replyMessage(replyToken, {
      type: 'text',
      text: `✅ シフトが作成されました！\n\n📅 作成されたシフト:\n${shiftsText}${classesText}\n\n承認をお待ちください。`
    });

  } catch (error) {
    console.error('Error processing advanced shift creation:', error);
    await client.replyMessage(replyToken, {
      type: 'text',
      text: 'シフトの作成中にエラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

// ネイティブ日付選択の処理
const handleNativeDateSelection = async (client: Client, replyToken: string, event: any, lineUserId: string) => {
  try {
    const hashedLineUserId = crypto.createHash('sha256').update(lineUserId).digest('hex');
    const sessionRef = admin.firestore().collection('line_shift_sessions').doc(hashedLineUserId);
    const sessionDoc = await sessionRef.get();

    if (!sessionDoc.exists) {
      await client.replyMessage(replyToken, {
        type: 'text',
        text: 'セッションが見つかりません。「シフト追加」からやり直してください。'
      });
      return;
    }

    const postbackData = JSON.parse(event.postback.data);
    const selectedDate = event.postback.params?.date;

    if (!selectedDate) {
      await client.replyMessage(replyToken, {
        type: 'text',
        text: '日付が選択されませんでした。もう一度お試しください。'
      });
      return;
    }

    console.log(`Native date selected: ${selectedDate}`);

    const session = sessionDoc.data();
    const selectedDates = session?.selectedDates || [];

    if (postbackData.step === 'first_date') {
      // 最初の日付を保存
      selectedDates.push(selectedDate);
      await sessionRef.update({ selectedDates: selectedDates });

      // 複数日追加するかを確認
      await client.replyMessage(replyToken, {
        type: 'template',
        altText: '日付選択完了',
        template: {
          type: 'buttons',
          title: `${selectedDate} を選択`,
          text: '他の日付も追加しますか？',
          actions: [
            {
              type: 'datetimepicker',
              label: '📅 他の日付も追加',
              mode: 'date',
              data: JSON.stringify({
                action: 'native_date_select',
                step: 'additional_date',
                userId: postbackData.userId
              })
            },
            {
              type: 'postback',
              label: '⏰ 時間選択に進む',
              data: JSON.stringify({
                action: 'proceed_to_time',
                userId: postbackData.userId
              })
            }
          ]
        }
      } as any);
    } else if (postbackData.step === 'additional_date') {
      // 追加の日付を保存
      if (!selectedDates.includes(selectedDate)) {
        selectedDates.push(selectedDate);
        await sessionRef.update({ selectedDates: selectedDates });
      }

      const datesText = selectedDates.map(date => new Date(date).toLocaleDateString('ja-JP')).join(', ');

      await client.replyMessage(replyToken, {
        type: 'template',
        altText: '日付追加完了',
        template: {
          type: 'buttons',
          title: `選択済み: ${selectedDates.length}日`,
          text: `${datesText}\n\n他の日付も追加しますか？`,
          actions: [
            {
              type: 'datetimepicker',
              label: '📅 さらに追加',
              mode: 'date',
              data: JSON.stringify({
                action: 'native_date_select',
                step: 'additional_date',
                userId: postbackData.userId
              })
            },
            {
              type: 'postback',
              label: '⏰ 時間選択に進む',
              data: JSON.stringify({
                action: 'proceed_to_time',
                userId: postbackData.userId
              })
            }
          ]
        }
      } as any);
    }
  } catch (error) {
    console.error('Error handling native date selection:', error);
    await client.replyMessage(replyToken, {
      type: 'text',
      text: 'エラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

// Flexカレンダーのフォールバック処理
const handleFlexCalendarFallback = async (client: Client, replyToken: string, postbackData: any, lineUserId: string) => {
  try {
    const hashedLineUserId = crypto.createHash('sha256').update(lineUserId).digest('hex');
    const mapping = { hashedLineUserId, lineUserId, encryptedFirebaseUid: postbackData.userId };

    await sendCalendarDatePicker(client, replyToken, mapping);
  } catch (error) {
    console.error('Error handling flex calendar fallback:', error);
    await client.replyMessage(replyToken, {
      type: 'text',
      text: 'エラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

// 時間選択に進む処理
const handleProceedToTime = async (client: Client, replyToken: string, postbackData: any, lineUserId: string) => {
  try {
    const hashedLineUserId = crypto.createHash('sha256').update(lineUserId).digest('hex');
    const sessionRef = admin.firestore().collection('line_shift_sessions').doc(hashedLineUserId);

    await sessionRef.update({
      currentStep: 'time_selection'
    });

    const mapping = { hashedLineUserId, lineUserId, encryptedFirebaseUid: postbackData.userId };
    await sendTimePickerMenu(client, replyToken, mapping, 'start');
  } catch (error) {
    console.error('Error proceeding to time selection:', error);
    await client.replyMessage(replyToken, {
      type: 'text',
      text: 'エラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

// 高度なシフト作成の開始
// Temporarily disabled for testing
const startAdvancedShiftCreation_DISABLED = async (client: Client, replyToken: string, lineUserId: string) => {
  try {
    console.log(`Starting advanced shift creation for user: ${lineUserId}`);

    // ユーザーマッピングを取得
    const hashedLineUserId = crypto.createHash('sha256').update(lineUserId).digest('hex');
    const mappingDoc = await admin.firestore()
      .collection('line_user_mappings')
      .doc(hashedLineUserId)
      .get();

    if (!mappingDoc.exists) {
      await client.replyMessage(replyToken, {
        type: 'text',
        text: 'アカウント連携が必要です。まず「認証」と入力してアカウント連携を行ってください。'
      });
      return;
    }

    const mapping = mappingDoc.data();
    if (!mapping || !mapping.encryptedFirebaseUid) {
      await client.replyMessage(replyToken, {
        type: 'text',
        text: 'ユーザー情報の取得に失敗しました。「認証」からやり直してください。'
      });
      return;
    }

    // 新しいシフト作成セッションを初期化
    await admin.firestore()
      .collection('line_shift_sessions')
      .doc(hashedLineUserId)
      .set({
        userId: mapping.encryptedFirebaseUid,
        currentStep: 'date_selection',
        selectedDates: [],
        classes: [],
        createdAt: Date.now()
      });

    console.log('Sending advanced shift creation menu...');

    // LINE公式のDatetime Picker Actionを使用
    await client.replyMessage(replyToken, {
      type: 'template',
      altText: 'シフトの日付を選択してください',
      template: {
        type: 'buttons',
        title: '📅 高度なシフト作成',
        text: 'アプリと同じように詳細にシフトを作成できます。\n\nまず日付を選択してください。',
        actions: [
          {
            type: 'datetimepicker',
            label: '📅 日付を選択',
            mode: 'date',
            data: JSON.stringify({
              action: 'native_date_select',
              step: 'first_date',
              userId: mapping.encryptedFirebaseUid
            })
          },
          {
            type: 'postback',
            label: '⚙️ 従来の方法を使用',
            data: JSON.stringify({
              action: 'use_flex_calendar',
              userId: mapping.encryptedFirebaseUid
            })
          }
        ]
      }
    } as any);

    console.log('Advanced shift creation menu sent successfully');
  } catch (error) {
    console.error('Error starting advanced shift creation:', error);
    await client.replyMessage(replyToken, {
      type: 'text',
      text: 'エラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

