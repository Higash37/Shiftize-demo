/**
 * 日付フォーマット (YYYY-MM-DD)
 */
const formatDate = (date: Date): string => {
  return date.toISOString().split('T')[0];
};

/**
 * 日付表示フォーマット
 */
const formatDateDisplay = (date: Date, prefix?: string): string => {
  const formatted = `${date.getMonth() + 1}/${date.getDate()}`;
  return prefix ? `${prefix} (${formatted})` : formatted;
};

/**
 * LINE認証コード生成API
 */
export const generateLineAuthCode = functions
  .region('asia-northeast1')
  .https.onCall(async (data, context) => {
  try {
    // 認証チェック
    if (!context.auth) {
      throw new functions.https.HttpsError('unauthenticated', 'User must be authenticated');
    }

    // LINE User IDは不要にする（実際のLINE連携時に取得）
    const firebaseUid = context.auth.uid;
    const authCode = generateAuthCode();
    const expiresAt = new Date(Date.now() + 5 * 60 * 1000); // 5分後

    console.log(`Generating auth code for Firebase UID: ${firebaseUid}`);

    // 認証コードデータ
    const authCodeData = {
      authCode,
      firebaseUid,
      expiresAt,
      attempts: 0,
      isUsed: false,
      createdAt: admin.firestore.FieldValue.serverTimestamp()
    };

    // 既存の未使用認証コードを無効化
    const existingCodesRef = admin.firestore().collection('line_auth_codes');
    const existingSnapshot = await existingCodesRef
      .where('firebaseUid', '==', firebaseUid)
      .where('isUsed', '==', false)
      .get();

    const batch = admin.firestore().batch();
    existingSnapshot.forEach(doc => {
      batch.update(doc.ref, { isUsed: true });
    });

    // 新しい認証コードを保存
    const newAuthCodeRef = admin.firestore().collection('line_auth_codes').doc();
    batch.set(newAuthCodeRef, authCodeData);

    await batch.commit();

    return {
      authCode,
      expiresAt: expiresAt.toISOString()
    };

  } catch (error) {
    console.error('Generate LINE auth code error:', error);
    if (error instanceof functions.https.HttpsError) {
      throw error;
    }
    throw new functions.https.HttpsError('internal', 'Failed to generate auth code');
  }
});