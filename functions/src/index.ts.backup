/**
 * ユーザーマッピング取得
 */
const getUserMapping = async (userId: string) => {
  try {
    const hashedUserId = hashLineUserId(userId);
    const mappingsRef = admin.firestore().collection('line_user_mappings');
    
    // TODO: 効率的な検索のため複合インデックスの設定が必要
    const snapshot = await mappingsRef
      .where('hashedLineUserId', '==', hashedUserId)
      .where('isActive', '==', true)
      .limit(1)
      .get();
    
    if (snapshot.empty) {
      return null;
    }
    
    return snapshot.docs[0].data();
  } catch (error) {
    console.error('Get user mapping error:', error);
    return null;
  }
};

/**
 * シフト作成処理
 */
const handleShiftCreate = async (
  client: Client, 
  userId: string, 
  replyToken: string, 
  type: 'today' | 'tomorrow' | 'date', 
  dateString?: string
) => {
  try {
    // ユーザー認証状態チェック
    const mapping = await getUserMapping(userId);
    if (!mapping) {
      await client.replyMessage(replyToken, {
        type: 'text',
        text: '先にアカウント連携が必要です。「認証」と入力してください。'
      });
      return;
    }

    // 日付計算
    let targetDate: string;
    const today = new Date();
    
    switch (type) {
      case 'today':
        targetDate = formatDate(today);
        break;
      case 'tomorrow':
        const tomorrow = new Date(today);
        tomorrow.setDate(tomorrow.getDate() + 1);
        targetDate = formatDate(tomorrow);
        break;
      case 'date':
        if (!dateString || !/^\d{4}-\d{2}-\d{2}$/.test(dateString)) {
          await client.replyMessage(replyToken, {
            type: 'text',
            text: '日付の形式が正しくありません。YYYY-MM-DD形式で入力してください。'
          });
          return;
        }
        targetDate = dateString;
        break;
      default:
        targetDate = formatDate(today);
    }

    // 時間選択メニューを送信
    await sendTimeSelectionMenu(client, replyToken, targetDate, mapping);

  } catch (error) {
    console.error('Shift create error:', error);
    await client.replyMessage(replyToken, {
      type: 'text',
      text: 'シフト作成中にエラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

// 古いsendDateSelectionMessage関数を削除

// 高度なシフト作成の一時データを保存するためのインターフェース
interface ShiftCreationSession {
  userId: string;
  currentStep: 'date_selection' | 'time_selection' | 'class_selection' | 'confirmation';
  selectedDates: string[];
  selectedStartTime?: string;
  selectedEndTime?: string;
  classes: Array<{
    startTime: string;
    endTime: string;
  }>;
  createdAt: number;
}

// より本格的なカレンダーUIを作成
const createCalendarBubble = (year: number, month: number, existingDates: string[], userId?: string) => {
  const firstDay = new Date(year, month, 1);
  const lastDay = new Date(year, month + 1, 0);
  const firstDayOfWeek = firstDay.getDay();
  const monthNames = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];

  // 週を構築
  const weeks = [];
  let currentWeek = [];

  // 前月の最後の日付を取得して薄く表示（月またぎ対応）
  const prevMonth = month === 0 ? 11 : month - 1;
  const prevYear = month === 0 ? year - 1 : year;
  const prevMonthLastDay = new Date(prevYear, prevMonth + 1, 0).getDate();

  // 前月の日付で空白を埋める
  for (let i = 0; i < firstDayOfWeek; i++) {
    const prevDay = prevMonthLastDay - (firstDayOfWeek - 1 - i);
    const prevDateStr = `${prevYear}-${String(prevMonth + 1).padStart(2, '0')}-${String(prevDay).padStart(2, '0')}`;

    currentWeek.push({
      type: 'box',
      layout: 'vertical',
      contents: [{
        type: 'text',
        text: String(prevDay),
        size: 'xs',
        align: 'center',
        color: '#cccccc'
      }],
      flex: 1,
      height: '40px',
      backgroundColor: '#f8f8f8',
      action: {
        type: 'postback',
        data: JSON.stringify({
          action: 'toggle_date',
          date: prevDateStr,
          userId: userId || 'placeholder'
        })
      }
    });
  }

  // 日付を追加
  for (let day = 1; day <= lastDay.getDate(); day++) {
    const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
    const isSelected = existingDates.includes(dateStr);
    const isPast = new Date(year, month, day) < new Date(new Date().setHours(0, 0, 0, 0));

    currentWeek.push({
      type: 'box',
      layout: 'vertical',
      contents: [{
        type: 'text',
        text: isSelected ? `●${day}` : String(day),
        size: 'sm',
        align: 'center',
        color: isPast ? '#cccccc' : (isSelected ? '#ffffff' : '#333333'),
        weight: isSelected ? 'bold' : 'regular'
      }],
      flex: 1,
      height: '40px',
      backgroundColor: isPast ? '#f0f0f0' : (isSelected ? '#1DB446' : '#ffffff'),
      borderWidth: '1px',
      borderColor: '#e0e0e0',
      action: {
        type: 'postback',
        data: JSON.stringify({
          action: 'toggle_date',
          date: dateStr,
          userId: userId || 'placeholder'
        })
      }
    });

    // 週末で改行
    if (currentWeek.length === 7) {
      weeks.push({
        type: 'box',
        layout: 'horizontal',
        contents: currentWeek,
        spacing: 'xs'
      });
      currentWeek = [];
    }
  }

  // 最後の週を次月の日付で埋める
  const nextMonth = month === 11 ? 0 : month + 1;
  const nextYear = month === 11 ? year + 1 : year;
  let nextDay = 1;

  while (currentWeek.length < 7) {
    const nextDateStr = `${nextYear}-${String(nextMonth + 1).padStart(2, '0')}-${String(nextDay).padStart(2, '0')}`;

    currentWeek.push({
      type: 'box',
      layout: 'vertical',
      contents: [{
        type: 'text',
        text: String(nextDay),
        size: 'xs',
        align: 'center',
        color: '#cccccc'
      }],
      flex: 1,
      height: '40px',
      backgroundColor: '#f8f8f8',
      action: {
        type: 'postback',
        data: JSON.stringify({
          action: 'toggle_date',
          date: nextDateStr,
          userId: userId || 'placeholder'
        })
      }
    });
    nextDay++;
  }

  if (currentWeek.length > 0) {
    weeks.push({
      type: 'box',
      layout: 'horizontal',
      contents: currentWeek,
      spacing: 'xs'
    });
  }

  return {
    type: 'bubble',
    header: {
      type: 'box',
      layout: 'vertical',
      contents: [
        {
          type: 'text',
          text: `${year}年${monthNames[month]}`,
          weight: 'bold',
          color: '#1DB446',
          size: 'lg',
          align: 'center'
        }
      ],
      backgroundColor: '#f8f9fa'
    },
    body: {
      type: 'box',
      layout: 'vertical',
      contents: [
        {
          type: 'box',
          layout: 'horizontal',
          contents: ['日', '月', '火', '水', '木', '金', '土'].map(day => ({
            type: 'text',
            text: day,
            size: 'xs',
            color: day === '日' ? '#ff6b6b' : (day === '土' ? '#4dabf7' : '#666666'),
            align: 'center',
            flex: 1,
            weight: 'bold'
          })),
          margin: 'md',
          spacing: 'xs'
        },
        ...weeks
      ],
      spacing: 'xs',
      paddingAll: 'md'
    }
  };
};

// カレンダー表示用の関数
const sendCalendarDatePicker = async (client: Client, replyToken: string, mapping: any, currentMonth?: Date) => {
  try {
    const now = currentMonth || new Date();
    const year = now.getFullYear();
    const month = now.getMonth();

    // 既存の選択データを取得
    const sessionDoc = await admin.firestore()
      .collection('line_shift_sessions')
      .doc(mapping.hashedLineUserId)
      .get();

    const existingDates = sessionDoc.exists ? sessionDoc.data()?.selectedDates || [] : [];

    // 新しいカレンダーUIを使用
    const calendarBubble = createCalendarBubble(year, month, existingDates, mapping.encryptedFirebaseUid);

    // ナビゲーションとアクションボタンを追加
    calendarBubble.footer = {
      type: 'box',
      layout: 'vertical',
      contents: [
        {
          type: 'box',
          layout: 'horizontal',
          contents: [
            {
              type: 'button',
              action: {
                type: 'postback',
                label: '← 前月',
                data: JSON.stringify({
                  action: 'prev_month',
                  year: month === 0 ? year - 1 : year,
                  month: month === 0 ? 11 : month - 1,
                  userId: mapping.encryptedFirebaseUid
                })
              },
              style: 'secondary',
              flex: 1
            },
            {
              type: 'button',
              action: {
                type: 'postback',
                label: '次月 →',
                data: JSON.stringify({
                  action: 'next_month',
                  year: month === 11 ? year + 1 : year,
                  month: month === 11 ? 0 : month + 1,
                  userId: mapping.encryptedFirebaseUid
                })
              },
              style: 'secondary',
              flex: 1
            }
          ],
          spacing: 'sm'
        },
        {
          type: 'button',
          action: {
            type: 'postback',
            label: existingDates.length > 0 ? `選択完了 (${existingDates.length}日選択済み)` : '日付を選択してください',
            data: JSON.stringify({
              action: 'confirm_dates',
              userId: mapping.encryptedFirebaseUid
            })
          },
          style: existingDates.length > 0 ? 'primary' : 'secondary',
          color: existingDates.length > 0 ? '#1DB446' : '#cccccc',
          margin: 'md'
        }
      ]
    };

    // デバッグログ
    console.log(`Calendar bubble contents count: ${calendarBubble.body.contents.length}`);

    await client.replyMessage(replyToken, {
      type: 'flex',
      altText: 'カレンダー - 日付選択',
      contents: calendarBubble
    } as any);
  } catch (error) {
    console.error('Error sending calendar:', error);
    await client.replyMessage(replyToken, {
      type: 'text',
      text: 'エラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

// 15分刻み時間選択の送信
const sendTimePickerMenu = async (client: Client, replyToken: string, mapping: any, timeType: 'start' | 'end') => {
  try {
    // 15分刻みの時間オプションを生成
    const generateTimeOptions = () => {
      const options = [];
      for (let hour = 9; hour <= 22; hour++) {
        for (let minute = 0; minute < 60; minute += 15) {
          const timeString = `${String(hour).padStart(2, '0')}:${String(minute).padStart(2, '0')}`;
          options.push(timeString);
        }
      }
      return options;
    };

    const timeOptions = generateTimeOptions();
    const timeButtons = timeOptions.map(time => ({
      type: 'action',
      action: {
        type: 'postback',
        label: time,
        data: JSON.stringify({
          action: 'select_time',
          timeType: timeType,
          time: time,
          userId: mapping.encryptedFirebaseUid
        })
      }
    }));

    // Quick Replyで時間選択
    await client.replyMessage(replyToken, {
      type: 'text',
      text: `${timeType === 'start' ? '開始' : '終了'}時間を選択してください：`,
      quickReply: {
        items: timeButtons.slice(0, 13) // Quick Replyは最大13個まで
      }
    } as any);

    // 残りの時間オプションがある場合は追加でFlexメッセージを送信
    if (timeOptions.length > 13) {
      const remainingOptions = timeOptions.slice(13);
      const flexButtons = remainingOptions.map(time => ({
        type: 'button',
        action: {
          type: 'postback',
          label: time,
          data: JSON.stringify({
            action: 'select_time',
            timeType: timeType,
            time: time,
            userId: mapping.encryptedFirebaseUid
          })
        },
        style: 'secondary',
        color: '#666666'
      }));

      // Flexメッセージのボタンは12個まで制限があるため、複数のメッセージに分割
      const buttonChunks = [];
      for (let i = 0; i < flexButtons.length; i += 12) {
        buttonChunks.push(flexButtons.slice(i, i + 12));
      }

      for (const chunk of buttonChunks) {
        await client.pushMessage(mapping.lineUserId, {
          type: 'flex',
          altText: '時間選択（続き）',
          contents: {
            type: 'bubble',
            body: {
              type: 'box',
              layout: 'vertical',
              contents: chunk
            }
          }
        } as any);
      }
    }
  } catch (error) {
    console.error('Error sending time selection:', error);
    await client.replyMessage(replyToken, {
      type: 'text',
      text: 'エラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

// 新しいpostbackハンドラー関数群

// 日付選択のトグル処理
const handleDateToggle = async (client: Client, replyToken: string, postbackData: any, lineUserId: string) => {
  try {
    const hashedLineUserId = crypto.createHash('sha256').update(lineUserId).digest('hex');
    const sessionRef = admin.firestore().collection('line_shift_sessions').doc(hashedLineUserId);
    const sessionDoc = await sessionRef.get();

    if (!sessionDoc.exists) {
      await client.replyMessage(replyToken, {
        type: 'text',
        text: 'セッションが見つかりません。「シフト追加」からやり直してください。'
      });
      return;
    }

    const session = sessionDoc.data() as ShiftCreationSession;
    const selectedDates = session.selectedDates || [];
    const dateToToggle = postbackData.date;

    // 日付のトグル処理
    if (selectedDates.includes(dateToToggle)) {
      // 選択を解除
      const newDates = selectedDates.filter(d => d !== dateToToggle);
      await sessionRef.update({ selectedDates: newDates });
    } else {
      // 選択を追加
      selectedDates.push(dateToToggle);
      await sessionRef.update({ selectedDates: selectedDates });
    }

    // 更新されたカレンダーを再表示
    const mapping = { hashedLineUserId, lineUserId };
    await sendCalendarDatePicker(client, replyToken, mapping);
  } catch (error) {
    console.error('Error handling date toggle:', error);
    await client.replyMessage(replyToken, {
      type: 'text',
      text: 'エラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

// 月のナビゲーション処理
const handleMonthNavigation = async (client: Client, replyToken: string, postbackData: any, lineUserId: string) => {
  try {
    const hashedLineUserId = crypto.createHash('sha256').update(lineUserId).digest('hex');
    const mapping = { hashedLineUserId, lineUserId };

    const targetDate = new Date(postbackData.year, postbackData.month, 1);
    await sendCalendarDatePicker(client, replyToken, mapping, targetDate);
  } catch (error) {
    console.error('Error handling month navigation:', error);
    await client.replyMessage(replyToken, {
      type: 'text',
      text: 'エラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

// 日付選択の確定処理
const handleDateConfirmation = async (client: Client, replyToken: string, postbackData: any, lineUserId: string) => {
  try {
    const hashedLineUserId = crypto.createHash('sha256').update(lineUserId).digest('hex');
    const sessionRef = admin.firestore().collection('line_shift_sessions').doc(hashedLineUserId);
    const sessionDoc = await sessionRef.get();

    if (!sessionDoc.exists) {
      await client.replyMessage(replyToken, {
        type: 'text',
        text: 'セッションが見つかりません。「シフト追加」からやり直してください。'
      });
      return;
    }

    const session = sessionDoc.data() as ShiftCreationSession;
    const selectedDates = session.selectedDates || [];

    if (selectedDates.length === 0) {
      await client.replyMessage(replyToken, {
        type: 'text',
        text: '日付を1つ以上選択してください。'
      });
      return;
    }

    // ステップを時間選択に進める
    await sessionRef.update({
      currentStep: 'time_selection'
    });

    const mapping = { hashedLineUserId, lineUserId, encryptedFirebaseUid: postbackData.userId };
    await sendTimePickerMenu(client, replyToken, mapping, 'start');
  } catch (error) {
    console.error('Error handling date confirmation:', error);
    await client.replyMessage(replyToken, {
      type: 'text',
      text: 'エラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

// 時間選択処理
const handleTimeSelection = async (client: Client, replyToken: string, postbackData: any, lineUserId: string) => {
  try {
    const hashedLineUserId = crypto.createHash('sha256').update(lineUserId).digest('hex');
    const sessionRef = admin.firestore().collection('line_shift_sessions').doc(hashedLineUserId);
    const sessionDoc = await sessionRef.get();

    if (!sessionDoc.exists) {
      await client.replyMessage(replyToken, {
        type: 'text',
        text: 'セッションが見つかりません。「シフト追加」からやり直してください。'
      });
      return;
    }

    const session = sessionDoc.data() as ShiftCreationSession;
    const { timeType, time } = postbackData;
    const mapping = { hashedLineUserId, lineUserId, encryptedFirebaseUid: postbackData.userId };

    if (timeType === 'start') {
      // 開始時間を保存して終了時間選択へ
      await sessionRef.update({
        selectedStartTime: time
      });

      await sendTimePickerMenu(client, replyToken, mapping, 'end');
    } else if (timeType === 'end') {
      // 終了時間を保存してクラス選択へ
      await sessionRef.update({
        selectedEndTime: time,
        currentStep: 'class_selection'
      });

      // クラス追加オプションを表示
      await sendClassSelectionMenu(client, replyToken, mapping);
    }
  } catch (error) {
    console.error('Error handling time selection:', error);
    await client.replyMessage(replyToken, {
      type: 'text',
      text: 'エラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

