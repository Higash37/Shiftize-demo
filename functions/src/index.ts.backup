/**
 * 認証コード処理
 */
const handleAuthCode = async (client: Client, userId: string, authCode: string) => {
  try {
    console.log(`Processing auth code: ${authCode} for user: ${userId.substring(0, 8)}...`);

    // Firestoreから認証コードを検索（authCodeのみで検索）
    const authCodesRef = admin.firestore().collection('line_auth_codes');
    const snapshot = await authCodesRef
      .where('authCode', '==', authCode)
      .where('isUsed', '==', false)
      .limit(1)
      .get();

    console.log(`Found ${snapshot.size} matching auth codes`);

    if (snapshot.empty) {
      await client.pushMessage(userId, {
        type: 'text',
        text: '認証コードが正しくないか、有効期限が切れています。アプリで新しい認証コードを生成してください。'
      });
      return;
    }

    const authDoc = snapshot.docs[0];
    const authData = authDoc.data();

    // 有効期限チェック
    if (new Date() > authData.expiresAt.toDate()) {
      await client.pushMessage(userId, {
        type: 'text',
        text: '認証コードの有効期限が切れています。アプリで新しい認証コードを生成してください。'
      });
      return;
    }

    // ユーザー情報取得
    const userDoc = await admin.firestore().collection('users').doc(authData.firebaseUid).get();
    if (!userDoc.exists) {
      await client.pushMessage(userId, {
        type: 'text',
        text: 'ユーザー情報が見つかりません。管理者にお問い合わせください。'
      });
      return;
    }

    const userData = userDoc.data()!;
    const hashedUserId = hashLineUserId(userId);

    console.log(`Creating LINE mapping for user: ${userData.nickname}`);

    // LINE連携情報を保存
    const mappingData = {
      hashedLineUserId: hashedUserId,
      encryptedFirebaseUid: authData.firebaseUid, // TODO: 暗号化実装
      encryptedNickname: userData.nickname, // TODO: 暗号化実装
      storeId: userData.storeId,
      role: userData.role,
      isActive: true,
      lastUsedAt: admin.firestore.FieldValue.serverTimestamp(),
      createdAt: admin.firestore.FieldValue.serverTimestamp(),
      updatedAt: admin.firestore.FieldValue.serverTimestamp()
    };

    await admin.firestore()
      .collection('line_user_mappings')
      .doc(authData.firebaseUid)
      .set(mappingData);

    // 認証コードを使用済みにマーク
    await authDoc.ref.update({ isUsed: true });

    await client.pushMessage(userId, {
      type: 'text',
      text: `認証が完了しました！\n${userData.nickname}さん、こんにちは。\n\n以下のコマンドが利用できます:\n• シフト追加\n• 予定確認\n\nシフト追加から始めましょう！`
    });

  } catch (error) {
    console.error('Auth code handling error:', error);
    await client.pushMessage(userId, {
      type: 'text',
      text: '認証処理中にエラーが発生しました。しばらくしてから再度お試しください。'
    });
  }
};

