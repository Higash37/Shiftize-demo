# =============================================================================
# Supabase設定（必須）
# =============================================================================
# Supabaseダッシュボード > Settings > API から取得
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_USE_SUPABASE=true

# =============================================================================
# Google OAuth設定（任意 — Google Calendar連携を使う場合のみ）
# =============================================================================
# Google Cloud Console > 認証情報 > OAuth 2.0 クライアントID
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# =============================================================================
# API設定（通常変更不要）
# =============================================================================
EXPO_PUBLIC_USE_SHIFT_API=false
EXPO_PUBLIC_API_BASE_URL=""

# =============================================================================
# Expo設定（任意）
# =============================================================================
EXPO_PUBLIC_PROJECT_ID="your-expo-project-id"

# =============================================================================
# 天気情報設定（任意 — 気象庁オープンデータ）
# =============================================================================
# エリアコード一覧: https://www.jma.go.jp/bosai/common/const/area.json
EXPO_PUBLIC_JMA_AREA_CODE="130000"
