# Docker ignore file for Shiftize
# Excludes files and directories from the Docker build context

# Node modules
node_modules/
functions/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
# dist/ # Keep dist for simple Dockerfile
build/
.expo/
.expo-shared/

# Development and testing
.env.local
.env.development.local
.env.test.local
.env.production.local
.cache/
coverage/
.nyc_output/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# Documentation and development files
README.md
*.md
docs/
.github/

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Expo specific
.expo-shared/
expo-env.d.ts

# TypeScript
*.tsbuildinfo

# ESLint cache
.eslintcache

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test
.env.*.local

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt

# Gatsby files
.cache/
public

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# IDE and editor files
*.sublime-project
*.sublime-workspace
.vscode/
.idea/

# OS and system files
*.pid
*.seed
*.pid.lock

# Runtime data
pids/
*.pid
*.seed

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output/

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env

# Bundle analyzer
report.html

# Docker files (to avoid recursion)
Dockerfile*
docker-compose*
.dockerignore

# Deployment specific
vercel.json
.vercel/

# Test files and directories (if you don't want them in production)
__tests__/
**/*.test.js
**/*.test.ts
**/*.test.tsx
**/*.spec.js
**/*.spec.ts
**/*.spec.tsx

# Playwright
test-results/
playwright-report/
playwright/.cache/

# MacOS
.DS_Store

# Windows
Thumbs.db