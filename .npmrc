# =============================================================================
# 🚀 React Native/Expo プロジェクト用 .npmrc 設定
# =============================================================================
# エンタープライズ級シフト管理アプリケーション専用設定
# TypeScript、Firestore、セキュリティ対策に最適化

# ✅ ログレベル調整（開発中の非推奨警告を抑制）
loglevel=warn

# ✅ peerDependencies のエラーを警告に変更（Expo/React Native互換性）
legacy-peer-deps=true

# ✅ インストール時の進捗バー非表示（クリーンな出力）
progress=false

# ✅ セキュリティ監査を一時的に無効化（開発時のノイズ削減）
audit=false

# ✅ package-lock.json の使用（依存関係の固定）
package-lock=true

# ✅ デフォルトレジストリ（npm公式）
registry=https://registry.npmjs.org/

# ✅ キャッシュ設定（CI/CD安定化）
cache-min=86400

# ✅ タイムアウト設定（ネットワーク不安定時対応）
timeout=120000

# =============================================================================
# 🔧 React Native/Expo 特有の設定
# =============================================================================

# ✅ npm fund メッセージを非表示
fund=false

# ✅ 厳密なSSL証明書チェック（セキュリティ強化）
strict-ssl=true

# ✅ 自動的にpackage.jsonを更新しない
save-exact=true

# =============================================================================
# 📝 使用上の注意
# =============================================================================
# 1. legacy-peer-deps=true は一時的措置。本番前に依存関係を見直すこと
# 2. audit=false は開発時のみ。定期的にnpm auditを手動実行推奨
# 3. このファイルは.gitignoreに含めない（チーム共有が必要）
# =============================================================================