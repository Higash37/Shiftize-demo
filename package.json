{
  "name": "Shiftize",
  "version": "2.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "cross-env EXPO_WEB_SUPPRESS_WARNINGS=1 expo start --web",
    "web:quiet": "expo start --web --quiet",
    "build": "cross-env EXPO_WEB_SUPPRESS_WARNINGS=1 expo export -p web",
    "lint": "npx eslint src --max-warnings=0",
    "vercel-build": "expo export -p web --output-dir dist",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "release:patch": "npm run version:patch && git add . && git commit -m \"chore: bump version to $(node -p \\\"require('./package.json').version\\\")\" && git push",
    "release:minor": "npm run version:minor && git add . && git commit -m \"chore: bump version to $(node -p \\\"require('./package.json').version\\\")\" && git push",
    "release:major": "npm run version:major && git add . && git commit -m \"chore: bump version to $(node -p \\\"require('./package.json').version\\\")\" && git push",
    "analyze:bundle": "npm run build && npx source-map-explorer dist/_expo/static/js/web/*.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/native": "^7.1.6",
    "@supabase/supabase-js": "2.95.3",
    "@types/react-dom": "~19.1.7",
    "crypto-js": "^4.2.0",
    "date-fns": "4.1.0",
    "expo": "54.0.33",
    "expo-constants": "~18.0.10",
    "expo-crypto": "15.0.8",
    "expo-font": "14.0.11",
    "expo-linking": "~8.0.8",
    "expo-router": "6.0.23",
    "expo-secure-store": "~15.0.7",
    "expo-status-bar": "~3.0.8",
    "html2canvas": "^1.4.1",
    "jspdf": "4.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "1.1314.0",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "0.21.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@eslint/js": "10.0.1",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "25.2.2",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "ajv": "8.17.1",
    "babel-plugin-module-resolver": "^5.0.0",
    "cross-env": "10.1.0",
    "eslint": "10.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "globals": "17.3.0",
    "metro": "^0.83.1",
    "source-map-explorer": "2.5.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.54.0"
  },
  "overrides": {
    "semver": "^7.7.2",
    "inflight": "npm:once@^1.4.0",
    "send": "^0.19.1",
    "react-native-calendars": {
      "react-native-safe-area-context": "5.6.1"
    }
  },
  "expo": {
    "install": {
      "exclude": [
        "@react-native-community/datetimepicker",
        "@react-native-picker/picker"
      ]
    }
  },
  "sideEffects": false,
  "private": true
}
