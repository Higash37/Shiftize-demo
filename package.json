{
  "name": "shift-scheduler-app",
  "version": "1.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "cross-env EXPO_WEB_SUPPRESS_WARNINGS=1 expo start --web",
    "web:quiet": "expo start --web --quiet",
    "build": "cross-env EXPO_WEB_SUPPRESS_WARNINGS=1 expo export -p web",
    "build:functions": "cd functions && npm run build",
    "build:all": "npm run build:functions && npm run build",
    "vercel-build": "expo export -p web --output-dir dist",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "release:patch": "npm run version:patch && git add . && git commit -m \"chore: bump version to $(node -p \\\"require('./package.json').version\\\")\" && git push",
    "release:minor": "npm run version:minor && git add . && git commit -m \"chore: bump version to $(node -p \\\"require('./package.json').version\\\")\" && git push",
    "release:major": "npm run version:major && git add . && git commit -m \"chore: bump version to $(node -p \\\"require('./package.json').version\\\")\" && git push",
    "analyze:bundle": "npm run build && npx source-map-explorer dist/_expo/static/js/web/*.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.5",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/native": "^7.1.6",
    "@types/react-dom": "19.1.9",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "expo": "54.0.22",
    "expo-constants": "~18.0.10",
    "expo-device": "~8.0.9",
    "expo-document-picker": "~14.0.7",
    "expo-font": "~14.0.9",
    "expo-linking": "~8.0.8",
    "expo-notifications": "~0.32.12",
    "expo-router": "~6.0.14",
    "expo-secure-store": "~15.0.7",
    "expo-status-bar": "~3.0.8",
    "firebase": "11.10.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1312.1",
    "react-native-safe-area-context": "5.6.1",
    "react-native-screens": "~4.17.1",
    "react-native-toast-message": "^2.2.1",
    "react-native-web": "0.21.2",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@eslint/js": "^9.24.0",
    "@playwright/test": "1.54.2",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "24.1.0",
    "@types/react": "~19.1.12",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "ajv": "8.17.1",
    "babel-plugin-module-resolver": "^5.0.0",
    "cross-env": "10.0.0",
    "eslint": "^9.24.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "globals": "^16.3.0",
    "metro": "^0.83.1",
    "source-map-explorer": "2.5.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.38.0"
  },
  "overrides": {
    "semver": "^7.7.2",
    "inflight": "npm:once@^1.4.0",
    "send": "^0.19.1",
    "react-native-calendars": {
      "react-native-safe-area-context": "5.6.1"
    }
  },
  "expo": {
    "install": {
      "exclude": [
        "@react-native-community/datetimepicker",
        "@react-native-picker/picker"
      ]
    }
  },
  "sideEffects": false,
  "private": true
}
