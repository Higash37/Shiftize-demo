rules_version = '2';

// Firebase Storage Rules - 一時的に緩和版（デバッグ用）
service firebase.storage {
  match /b/{bucket}/o {
    
    // 認証済みユーザーは全てのファイルにアクセス可能（一時的）
    match /files/{allPaths=**} {
      allow read, write, delete: if request.auth != null;
    }
    
    // その他のパスも認証済みユーザーはアクセス可能（一時的）
    match /{allPaths=**} {
      allow read, write, delete: if request.auth != null;
    }
  }
}