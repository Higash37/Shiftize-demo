rules_version = '2';

// Firebase Storage Rules for File Management System - Multi-Store Support
service firebase.storage {
  match /b/{bucket}/o {
    
    // ヘルパー関数
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function hasAccessToStore(storeId) {
      // 🔒 レガシー互換性を保ちつつセキュリティ強化
      let userDoc = firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
      let userStoreDoc = firestore.get(/databases/(default)/documents/userStoreAccess/$(request.auth.uid)).data;
      
      return (userDoc != null && userDoc.storeId == storeId) ||
             (userStoreDoc != null && 
              storeId in userStoreDoc.storesAccess &&
              userStoreDoc.storesAccess[storeId].isActive == true);
    }
    
    function isMasterOfStore(storeId) {
      return hasAccessToStore(storeId) &&
        (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "master");
    }
    
    function isValidFile() {
      // 🔒 ファイル検証ルール強化版
      return request.resource.size <= 50 * 1024 * 1024   // 最大50MB（セキュリティ強化）
             && request.resource.size > 0                 // 空ファイル拒否
             && (
               request.resource.contentType.matches('image/(jpeg|jpg|png|gif|webp)')  // 許可された画像のみ
               || request.resource.contentType.matches('video/(mp4|mov|avi)')         // 許可された動画のみ
               || request.resource.contentType == 'application/pdf'                   // PDF
               || request.resource.contentType.matches('application/(msword|vnd.openxmlformats-officedocument.wordprocessingml.document)') // Word
               || request.resource.contentType.matches('text/(plain|csv)')           // テキスト限定
             )
             && !request.resource.contentType.matches('.*(executable|script|php|js|html|svg).*') // 危険ファイル完全拒否
             && request.resource.name.size() <= 255;     // ファイル名長さ制限
    }
    
    function isValidFilename() {
      // ファイル名の安全性チェック
      let filename = request.resource.name;
      return !filename.matches('.*\\.\\..*')    // パストラバーサル防止
             && !filename.matches('.*/.*')       // パス区切り文字防止
             && !filename.matches('.*<.*')       // HTML文字防止
             && !filename.matches('.*>.*')
             && !filename.matches('.*".*')
             && !filename.matches(".*'.*");
    }
    
    // 店舗別ファイルアクセス - 多店舗対応の店舗分離
    match /files/{storeId}/{allPaths=**} {
      allow read: if isAuthenticated() && hasAccessToStore(storeId);
      allow write: if isAuthenticated() && hasAccessToStore(storeId) 
                      && isValidFile() && isValidFilename();
      allow delete: if isAuthenticated() && isMasterOfStore(storeId);
    }
    
    // PDFエクスポート用一時ファイル（共有用）
    match /exports/{storeId}/{filename} {
      allow read: if isAuthenticated() && hasAccessToStore(storeId);
      allow write: if isAuthenticated() && hasAccessToStore(storeId) 
                      && request.resource.contentType == 'application/pdf'
                      && isValidFilename();
      allow delete: if isAuthenticated() && hasAccessToStore(storeId);
    }
    
    // プロファイル画像（ユーザー個別）
    match /profiles/{userId}/{filename} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId
                      && request.resource.contentType.matches('image/.*')
                      && request.resource.size <= 5 * 1024 * 1024  // 5MB制限
                      && isValidFilename();
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // ルートファイルアクセス拒否
    match /files/{filename} {
      allow read, write: if false;
    }
    
    // その他のパスは全て拒否
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
} 